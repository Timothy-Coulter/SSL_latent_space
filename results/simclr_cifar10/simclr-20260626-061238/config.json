{
  "algorithm": {
    "name": "simclr",
    "queue_size": 4096,
    "momentum": 0.99,
    "temperature": 0.2,
    "byol_target_tau": 0.99,
    "swav_num_prototypes": 100,
    "swav_temperature": 0.1,
    "vicreg_invariance_weight": 25.0,
    "vicreg_variance_weight": 25.0,
    "vicreg_covariance_weight": 1.0
  },
  "model": {
    "backbone": "simple_cnn",
    "feature_dim": 128,
    "projection_dim": 128,
    "hidden_dim": 256
  },
  "optim": {
    "lr": 0.001,
    "weight_decay": 0.0001
  },
  "scheduler": {
    "name": "cosine",
    "interval": "epoch",
    "mode": "min",
    "monitor": "train/epoch_loss",
    "step_size": 10,
    "gamma": 0.1,
    "milestones": [
      30,
      60,
      90
    ],
    "t_max": 100,
    "t_0": 10,
    "t_mult": 1,
    "eta_min": 0.0,
    "power": 1.0,
    "warmup_steps": 100,
    "warmup_ratio": 0.1,
    "max_lr": null,
    "pct_start": 0.3,
    "div_factor": 25.0,
    "final_div_factor": 10000.0,
    "total_steps": null,
    "factor": 0.1,
    "patience": 10,
    "threshold": 0.0001,
    "cooldown": 0,
    "min_lr": 0.0
  },
  "data": {
    "dataset": "cifar10",
    "root": "datasets/data",
    "split": null,
    "download": false,
    "batch_size": 256,
    "num_workers": 8,
    "image_size": 32
  },
  "loop": {
    "epochs": 100,
    "steps_per_epoch": null,
    "seed": 0,
    "device": "cuda",
    "log_every_n_steps": 50,
    "verbose": 1
  },
  "early_stopping": {
    "enabled": true,
    "patience": 10,
    "min_delta": 0.0
  },
  "checkpoint": {
    "save_best": true,
    "save_final": true
  },
  "logging": {
    "enabled": true,
    "experiment": "simclr_cifar10",
    "results_dir": "results",
    "tensorboard_dir": "runs"
  },
  "post_pretrain_finetune": {
    "enabled": true,
    "finetune_config": "configs/defaults/finetune_cifar10.toml",
    "checkpoint": "best"
  }
}